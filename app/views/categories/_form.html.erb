<div class="p-3 border rounded bg-light mb-3">
  <%= form_with model: @category, local: true, data: { turbo: false } do |form| %>
    <% if @category.errors.any? %>
      <div class="alert alert-danger mb-3" role="alert">
        <% @category.errors.full_messages.each do |error| %>
          <div><%= error %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", placeholder: "Enter category name" %>
    </div>

    <div class="d-flex gap-2 justify-content-end">
      <%= form.submit class: "btn btn-sm btn-primary" %>
      <% if @category.new_record? %>
        <%= link_to t('actions.cancel'), categories_path, class: "btn btn-sm btn-secondary", data: { turbo_frame: "category_form" } %>
      <% else %>
        <%= link_to t('actions.cancel'), categories_path, class: "btn btn-sm btn-secondary", data: { turbo_frame: "_top" } %>
      <% end %>
    </div>
  <% end %>
</div>
