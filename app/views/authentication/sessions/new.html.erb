<div style="max-width: 500px; margin: 5rem auto; padding: 0 1rem;">
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <h2 class="card-title text-center mb-4"><%= 'Login' %></h2>
      
      <%= form_with(url: sessions_path, local: true) do |form| %>
        <div class="mb-3">
          <%= form.label :login, class: "form-label" %>
          <%= form.text_field :login, class: "form-control", placeholder: "Enter username", required: true %>
        </div>

        <div class="mb-3">
          <%= form.label :password, class: "form-label" %>
          <%= form.password_field :password, class: "form-control", placeholder: "Enter password", required: true %>
        </div>

        <div class="d-grid">
          <%= form.submit 'Login', class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <hr class="my-4">
      
      <p class="text-center mb-0">
        <%= 'Login' %>
        <%= link_to 'Register', users_path, class: "link-primary" %>
      </p>
    </div>
  </div>
</div>
