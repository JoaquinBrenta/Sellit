<%= turbo_frame_tag "modal" do %>
<div data-controller="modal">
<div class="modal" tabindex="-1">
  <div class="modal-dialog">
    <div data-modal-target="modalPop" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= @product.title %></h5>
         <i class="bi bi-x-lg" data-action="click->modal#close"></i>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <%= image_tag @product.image.attached? ? @product.image : 'placeholder.png', class: "img-fluid rounded w-100", style: "max-height: 300px; object-fit: cover;" %>
        </div>

         <div class="mb-3">
          <%= render partial: 'favorite', locals: { product: @product } %> 
        </div>

         <div class="mb-3">
          <h4 class="price"><%= number_to_currency(@product.price) %></h4>
        </div>
        
        <div class="mb-3">
          <p class="text-muted"><%= @product.description %></p>
        </div>

        <div class="mb-3">
          <small class="text-muted"><%= 'View more products by' %>: <%= link_to @product.user.username, user_path(@product.user.username), data: { turbo: false } %></small>
        </div>
      </div>
      
      <div class="modal-footer">
        <% if @product.owner? %>
          <%= link_to t('actions.edit'), edit_product_path(@product), class: "btn btn-warning btn-sm", data: {turbo_frame: "modal",turbo_confirm: 'Product edit successfully'} %>
          <%= button_to t('actions.delete'), product_path(@product), method: :delete, class: "btn btn-danger btn-sm", data: { confirm: t('common.confirm') }, form: { data: { turbo: false } } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
</div>
<div data-controller="websocket-product" data-productId="<%= @product.id %>"></div>
<% end %>