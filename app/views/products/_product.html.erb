<%= link_to product_path(product.id), class: 'product card col-sm-6 col-md-4 col-lg-3 col-xl-2', data: { turbo_frame: "modal" } do%>
<%= image_tag product.image.attached? ? product.image : 'placeholder.png', width: 100 %>
<div class="card-body">
<p class="price"><%= product.price %> $</p>
<h2><%= product.title %></h2>
<p class="description"><%= truncate(product.description, length: 100, separator: ' ', omission: '...') %></p>
</div>
<% end %>

